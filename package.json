{
  "name": "vengadores-oscuros",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:back\" \"npm:dev:front\"",
    "build": "npm run build --workspaces --if-present",
    "start": "concurrently \"npm:dev:back\" \"npm:dev:front\"",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:video": "PLAYWRIGHT_VIDEO=on playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "lint": "npm run lint --workspaces --if-present && prettier --check .",
    "lint:fix": "npm run lint:fix --workspaces --if-present && prettier --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:back": "npm run dev --workspace=packages/back",
    "dev:front": "npm run dev --workspace=packages/front",
    "build:back": "npm run build --workspace=packages/back",
    "build:front": "npm run build --workspace=packages/front",
    "start:back": "npm run start --workspace=packages/back",
    "start:front": "npm run start --workspace=packages/front",
    "test:back": "npm run test --workspace=packages/back",
    "test:front": "npm run test --workspace=packages/front",
    "lint:back": "npm run lint --workspace=packages/back",
    "lint:front": "npm run lint --workspace=packages/front",
    "typecheck:back": "npm run typecheck --workspace=packages/back",
    "typecheck:front": "npm run typecheck --workspace=packages/front",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose up --build",
    "clean": "rm -rf node_modules package-lock.json packages/*/node_modules packages/*/package-lock.json packages/*/dist packages/*/build packages/*/coverage playwright-report test-results .nyc_output junit.xml *.tsbuildinfo packages/*/*.tsbuildinfo packages/*/*.log *.log"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "overrides": {
    "eslint": "^10.1.0"
  }
}
